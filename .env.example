# PostgreSQL (lokalt via docker compose, eller Neon i produktion)
DATABASE_URL=postgresql://auth:auth@localhost:5432/authms

NODE_HOSTNAME=127.0.0.1
NODE_PORT=3000
NODE_NAME=flodet
NODE_ENV=development

# JWT för inloggning (sätt starkt värde i produktion / Netlify)
JWT_SECRET=change-me-in-production

# Publik sajt-URL (för återställningslänkar i e-post)
PUBLIC_SITE_URL=https://community-auth-platform.netlify.app

# Valfritt: Resend.com för e-post (glömt lösenord / användarnamn)
# RESEND_API_KEY=re_xxxx
# EMAIL_FROM=Flödet <noreply@din-domän.se>

# Valfritt: filbaserad loggning
# NODE_LOG_PATH=./logs
