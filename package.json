{
  "name": "community-auth-forum",
  "version": "4.1.0",
  "description": "Flödet – socialt nätverk med profiler, vänner och flöde (Node.js + PostgreSQL)",
  "type": "commonjs",
  "main": "build/app/index.js",
  "engines": {
    "node": ">=20.13.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node build/app/index.js",
    "dev": "tsx watch src/app/index.ts",
    "test": "mocha --exit -r tsx/cjs src/tests/**/*.spec.ts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "tsx scripts/migrate.ts",
    "audit": "npm audit",
    "docs:openapi": "echo 'OpenAPI: docs/openapi.yaml and public/openapi.yaml'"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "sanitize-html": "^2.17.4",
    "serverless-http": "^3.2.0",
    "winston": "^3.17.0"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/chai": "^5.2.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.0",
    "@types/sanitize-html": "^2.16.0",
    "chai": "^5.2.0",
    "mocha": "^11.7.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
